SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
PORT=4000
NODE_ENV=production
# Comma-separated list of frontend origins allowed to call this API from a browser.
ALLOWED_ORIGINS=https://your-frontend-domain.com
SMTP_EMAIL=your-gmail@gmail.com
SMTP_PASSWORD=your-gmail-app-password

# PayMongo (QRPh invoices) — https://dashboard.paymongo.com/developers/api-keys
# Use sk_test_... while developing; switch to sk_live_... to go live.
PAYMONGO_SECRET_KEY=sk_test_your-secret-key
# From Dashboard → Developers → Webhooks → your endpoint → Signing secret
# (register the endpoint at https://your-domain/api/payments/webhook/paymongo)
PAYMONGO_WEBHOOK_SECRET=whsk_your-webhook-signing-secret

# SMS Mobile API (https://smsmobileapi.com) — relays SMS through a phone
# running their app, connected to your account. Get the key from your
# smsmobileapi.com dashboard.
SMSMOBILEAPI_KEY=your-smsmobileapi-key
